import { getAllPosts, getFeaturedPosts } from '@/lib/posts'
import { CATEGORY_META as CAT } from '@/lib/categories'
import { PostCard } from '@/components/blog/PostCard'
import { WebsiteJsonLd } from '@/components/seo/JsonLd'
import { EmailCapture } from '@/components/monetization/EmailCapture'
import Link from 'next/link'
import Image from 'next/image'
import type { Metadata } from 'next'

export const revalidate = 1800

export const metadata: Metadata = {
  title: 'Blixamo — Self-Hosting, DevOps & AI Automation for Indie Developers',
  description: 'Self-hosting, DevOps, AI automation and indie hacking guides for developers building real products on Hetzner and Next.js.',
  alternates: { canonical: 'https://blixamo.com' },
}

const CATEGORY_META: Record<string, { icon: string; color: string; label: string; desc: string }> = {
  'self-hosting': { icon: '🖥',  color: '#0891b2', label: 'Self-Hosting',         desc: 'Run your own apps on a €5/mo VPS.' },
  devops:          { icon: '⚙️',  color: '#059669', label: 'DevOps & Infrastructure', desc: 'VPS, Nginx, PM2, Docker — real infra.' },
  'ai-automation': { icon: '🤖', color: '#7c3aed', label: 'AI Automation',          desc: 'Claude API, n8n, and AI workflows.' },
  'indie-hacking': { icon: '🚀', color: '#e11d48', label: 'Indie Hacking',          desc: 'SaaS, payments, building solo in India.' },
  tools:          { icon: '🛠',  color: '#d97706', label: 'Tools & Comparison',   desc: 'Honest tool comparisons, no fluff.' },
}

// Featured articles driven by frontmatter featured:true — no rebuild needed to change
// Falls back to first 3 posts if no featured posts set
function getFeaturedSlugs(posts: ReturnType<typeof getAllPosts>) {
  const featured = posts.filter(p => p.featured).slice(0, 3)
  if (featured.length >= 2) return featured.map(p => ({ slug: p.slug, label: p.title }))
  // fallback
  return [
    { slug: 'deploy-nextjs-coolify-hetzner',    label: 'Deploy Next.js on Hetzner with Coolify' },
    { slug: 'multiple-projects-single-vps',     label: 'Run 5 Projects on One Hetzner VPS' },
    { slug: 'nextjs-mdx-blog-2026',             label: 'Build a Next.js MDX Blog in 2026' },
  ]
}

const TOOLS = [
  { name: 'Next.js',    icon: '▲', href: 'https://nextjs.org' },
  { name: 'Docker',     icon: '🐳', href: 'https://docker.com' },
  { name: 'Cloudflare', icon: '🔶', href: 'https://cloudflare.com' },
  { name: 'Hetzner',    icon: '🟠', href: 'https://hetzner.com' },
  { name: 'Supabase',   icon: '⚡', href: 'https://supabase.com' },
  { name: 'n8n',        icon: '🔁', href: 'https://n8n.io' },
]

export default function HomePage() {
  const allPosts = getAllPosts()
  const popular  = allPosts.slice(0, 5)
  const latest   = allPosts.slice(0, 18)
  const FEATURED_SLUGS = getFeaturedSlugs(allPosts)

  return (
    <>
      <WebsiteJsonLd />

      {/* ── STATS BAR ── */}
      <div className="stats-bar">
        <div className="stat-item">📝 <strong>{allPosts.length}</strong> articles</div>
        <div className="stat-item">🖥 <strong>€5.19/mo</strong> Hetzner setup</div>
        <div className="stat-item">⚡ <strong>Self-hosted</strong> on Hetzner CPX22</div>
        <div className="stat-item">🇮🇳 <strong>India-first</strong> developer blog</div>
      </div>

      {/* ── 1. HERO ── */}
      <section style={{
        background: 'linear-gradient(135deg, var(--bg-subtle) 0%, var(--bg) 100%)',
        borderBottom: '1px solid var(--border)',
        padding: 'clamp(3rem, 8vw, 6rem) 1rem',
      }}>
        <div style={{ maxWidth: '800px', margin: '0 auto', textAlign: 'center' }}>
          <div style={{
            display: 'inline-flex', alignItems: 'center', gap: '0.5rem',
            padding: '0.35rem 1rem', borderRadius: '2rem', marginBottom: '1.5rem',
            background: 'var(--accent-soft)', border: '1px solid var(--accent)',
            fontSize: '0.78rem', fontWeight: 700, color: 'var(--accent)', letterSpacing: '0.08em',
          }}>
            🚀 PRACTICAL DEV TUTORIALS
          </div>
          <h1 style={{
            fontSize: 'clamp(2.2rem, 5.5vw, 3.5rem)', fontWeight: 900,
            lineHeight: 1.1, color: 'var(--text-primary)', marginBottom: '1.25rem',
          }}>
            Self-hosting, DevOps & AI automation<br />
            <span style={{ color: 'var(--accent)' }}>building real apps.</span>
          </h1>
          <p style={{
            fontSize: 'clamp(1rem, 2.5vw, 1.2rem)', color: 'var(--text-secondary)',
            lineHeight: 1.75, maxWidth: '640px', margin: '0 auto 2rem',
          }}>
            Learn how to deploy apps, self-host services, and build AI-powered tools
            using technologies like <strong>Next.js</strong> and affordable infrastructure
            such as <strong>Hetzner</strong>.
          </p>
          <div className="hero-cta-row" style={{ display: 'flex', gap: '1rem', justifyContent: 'center', flexWrap: 'wrap' }}>
            <Link href="/blog" style={{
              padding: '0.8rem 2rem', background: 'var(--accent)', color: '#fff',
              borderRadius: '0.6rem', fontWeight: 700, fontSize: '0.95rem',
              boxShadow: '0 4px 20px rgba(108,99,255,0.35)',
            }}>
              Start Reading →
            </Link>
            <Link href="/blog/multiple-projects-single-vps" style={{
              padding: '0.8rem 2rem', background: 'transparent', color: 'var(--text-primary)',
              borderRadius: '0.6rem', fontWeight: 700, fontSize: '0.95rem',
              border: '1px solid var(--border)',
            }}>
              Read the Latest Guide →
            </Link>
          </div>
        </div>
      </section>

      {/* ── 2. FEATURED TUTORIALS ── */}
      <section style={{ borderBottom: '1px solid var(--border)', padding: '3rem 1rem', background: 'var(--bg)' }}>
        <div style={{ maxWidth: '1100px', margin: '0 auto' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: '0.6rem', marginBottom: '1.5rem' }}>
            <span style={{ fontSize: '1.1rem' }}>⭐</span>
            <h2 style={{ fontSize: '1.3rem', fontWeight: 800, color: 'var(--text-primary)' }}>Featured Articles</h2>
          </div>
          <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(min(280px, 100%), 1fr))', gap: '1rem' }}>
            {FEATURED_SLUGS.map(({ slug, label }, i) => {
              const post = allPosts.find(p => p.slug === slug)
              const title = post?.title || label
              const desc  = post?.description || ''
              const rt    = post?.readingTime || ''
              const gradients = [
                'linear-gradient(135deg, #6c63ff 0%, #a78bfa 100%)',
                'linear-gradient(135deg, #0891b2 0%, #6c63ff 100%)',
                'linear-gradient(135deg, #059669 0%, #0891b2 100%)',
              ]
              return (
                <Link key={slug} href={`/blog/${slug}`} style={{
                  display: 'block', borderRadius: '0.875rem', overflow: 'hidden',
                  border: '1px solid var(--border)', background: 'var(--bg)',
                  textDecoration: 'none', transition: 'transform 0.15s, box-shadow 0.15s',
                }}>
                  <div style={{ height: '6px', background: gradients[i] }} />
                  <div style={{ padding: '1.25rem' }}>
                    <div style={{
                      display: 'inline-flex', alignItems: 'center', gap: '0.3rem',
                      fontSize: '0.72rem', fontWeight: 700, color: '#f59e0b',
                      marginBottom: '0.6rem', letterSpacing: '0.05em',
                    }}>
                      ⭐ FEATURED
                    </div>
                    <h3 style={{ fontSize: '1rem', fontWeight: 700, color: 'var(--text-primary)', lineHeight: 1.3, marginBottom: '0.5rem' }}>
                      {title}
                    </h3>
                    {desc && (
                      <p style={{ fontSize: '0.82rem', color: 'var(--text-secondary)', lineHeight: 1.6,
                        display: '-webkit-box', WebkitLineClamp: 2, WebkitBoxOrient: 'vertical', overflow: 'hidden', marginBottom: '0.75rem' }}>
                        {desc}
                      </p>
                    )}
                    {rt && <span style={{ fontSize: '0.75rem', color: 'var(--text-muted)' }}>⏱ {rt}</span>}
                  </div>
                </Link>
              )
            })}
          </div>
        </div>
      </section>

      {/* ── 3. CATEGORIES ── */}
      <section style={{ borderBottom: '1px solid var(--border)', padding: '3rem 1rem', background: 'var(--bg-subtle)' }}>
