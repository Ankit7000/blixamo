                  textDecoration: 'none',
                }}>
                  <div style={{
                    width: '2.75rem', height: '2.75rem', borderRadius: '0.6rem', flexShrink: 0,
                    background: `${meta.color}18`, display: 'flex', alignItems: 'center', justifyContent: 'center',
                    fontSize: '1.35rem',
                  }}>
                    {meta.icon}
                  </div>
                  <div>
                    <div style={{ fontWeight: 700, fontSize: '0.95rem', color: 'var(--text-primary)', marginBottom: '0.2rem' }}>
