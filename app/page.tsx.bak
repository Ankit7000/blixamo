                  <div style={{ display: 'flex', gap: '0.5rem', fontSize: '0.75rem', color: 'var(--text-muted)', flexWrap: 'wrap' }}>
                    <span>⏱ {post.readingTime}</span>
                    <span>·</span>
                    <span style={{ color: CATEGORY_META[post.category]?.color || 'var(--accent)', textTransform: 'capitalize' }}>
                      {CATEGORY_META[post.category]?.icon} {post.category}
                    </span>
                  </div>
                </div>
