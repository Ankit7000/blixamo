          {/* Popular Posts */}
          <h2 style={{ fontSize: '1.3rem', fontWeight: 800, color: 'var(--text-primary)', marginBottom: '1.25rem' }}>
            🔥 Popular on Blixamo
          </h2>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '0', border: '1px solid var(--border)', borderRadius: '0.875rem', overflow: 'hidden', background: 'var(--bg-subtle)' }}>
            {popular.map((post, i) => (
              <Link key={post.slug} href={`/blog/${post.slug}`} style={{
                display: 'flex', gap: '1rem', alignItems: 'flex-start',
                padding: '1rem 1.25rem',
                borderBottom: i < popular.length - 1 ? '1px solid var(--border)' : 'none',
