            ))}
          </div>
        </div>

        {/* RIGHT SIDEBAR — Author, Tools, Newsletter */}
        <aside className="homepage-sidebar" style={{ display: 'flex', flexDirection: 'column', gap: '2rem' }}>

          {/* About Author */}
          <div style={{ background: 'var(--bg-subtle)', border: '1px solid var(--border)', borderRadius: '0.875rem', padding: '1.5rem' }}>
            <img
              src="/images/ankit.jpg"
              alt="Ankit Sorathiya"
              style={{
                width: '3.5rem', height: '3.5rem', borderRadius: '50%', marginBottom: '1rem',
                objectFit: 'cover', display: 'block',
              }}
            />
            <h3 style={{ fontSize: '1rem', fontWeight: 700, color: 'var(--text-primary)', marginBottom: '0.25rem' }}>
              Ankit Sorathiya
            </h3>
            <div style={{ fontSize: '0.78rem', color: 'var(--accent)', fontWeight: 600, marginBottom: '0.75rem' }}>
              Full-Stack Developer
            </div>
            <p style={{ fontSize: '0.83rem', color: 'var(--text-secondary)', lineHeight: 1.65, marginBottom: '1rem' }}>
              Hi, I'm Ankit — a full-stack developer building apps with Next.js and Flutter.
              On Blixamo I share practical tutorials about deployment, self-hosting, and developer tools.
            </p>
            <Link href="/about" style={{ fontSize: '0.82rem', color: 'var(--accent)', fontWeight: 600 }}>
              Read my story →
            </Link>
          </div>

          {/* Newsletter */}
          <div style={{ background: 'linear-gradient(135deg, var(--accent-soft) 0%, var(--bg-subtle) 100%)', border: '1px solid var(--accent)', borderRadius: '0.875rem', padding: '1.5rem' }}>
            <div style={{ fontSize: '1.5rem', marginBottom: '0.6rem' }}>📬</div>
            <h3 style={{ fontSize: '1rem', fontWeight: 700, color: 'var(--text-primary)', marginBottom: '0.4rem' }}>
              Join the Blixamo Newsletter
            </h3>
            <p style={{ fontSize: '0.82rem', color: 'var(--text-secondary)', lineHeight: 1.65, marginBottom: '1rem' }}>
              Get developer tutorials about self-hosting apps, cheap cloud infrastructure, and AI tools for developers.
            </p>
            <EmailCapture placement="inline" />
          </div>

          {/* Developer Tools */}
          <div style={{ background: 'var(--bg-subtle)', border: '1px solid var(--border)', borderRadius: '0.875rem', padding: '1.25rem' }}>
            <h3 style={{ fontSize: '0.82rem', fontWeight: 700, color: 'var(--text-muted)', letterSpacing: '0.08em', textTransform: 'uppercase', marginBottom: '0.85rem' }}>
              🛠 Tools I Use
            </h3>
            <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.5rem' }}>
              {TOOLS.map(tool => (
                <a key={tool.name} href={tool.href} target="_blank" rel="noopener noreferrer" style={{
                  display: 'inline-flex', alignItems: 'center', gap: '0.35rem',
                  padding: '0.35rem 0.75rem', background: 'var(--bg)',
                  border: '1px solid var(--border)', borderRadius: '0.5rem',
                  fontSize: '0.8rem', fontWeight: 600, color: 'var(--text-secondary)',
