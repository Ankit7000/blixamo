                    </div>
                    <div style={{ fontSize: '0.8rem', color: 'var(--text-secondary)', lineHeight: 1.5 }}>
                      {meta.desc}
                    </div>
                    <div style={{ fontSize: '0.72rem', color: meta.color, fontWeight: 700, marginTop: '0.4rem' }}>
                      {count} article{count !== 1 ? 's' : ''}
                    </div>
                  </div>
                </Link>
              )
            })}
          </div>
        </div>
      </section>

      {/* ── 4. LATEST + 5. POPULAR + 7. AUTHOR ── */}
      <div style={{ maxWidth: '1100px', margin: '0 auto', padding: '3rem 1rem', display: 'grid', gridTemplateColumns: 'minmax(0,1fr) 300px', gap: '3rem' }}
        className="homepage-grid">

        {/* LEFT — Latest + Popular */}
        <div>
          {/* Latest Articles */}
          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: '1.25rem' }}>
            <h2 style={{ fontSize: '1.3rem', fontWeight: 800, color: 'var(--text-primary)' }}>Latest Articles</h2>
            <Link href="/blog" style={{ fontSize: '0.82rem', color: 'var(--accent)', fontWeight: 600 }}>View all →</Link>
