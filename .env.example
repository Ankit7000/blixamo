# =============================================
# Blixamo — Environment Variables
# Copy to .env.local and fill in values
# =============================================

# Site
NEXT_PUBLIC_SITE_URL=https://blixamo.com

# Google Analytics 4
# Get from: analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Microsoft Clarity — free heatmaps + session recordings
# Get from: clarity.microsoft.com → New Project → copy ID
NEXT_PUBLIC_CLARITY_ID=

# Google AdSense — add after reaching 300+ daily visitors
# Get from: adsense.google.com → Sites → Ad code
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_AD_SLOT_1=
NEXT_PUBLIC_AD_SLOT_2=
NEXT_PUBLIC_AD_SLOT_SIDEBAR=
NEXT_PUBLIC_AD_SLOT_FOOTER=

# ConvertKit — email newsletter
# Get from: app.convertkit.com → Settings → API
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# MailerLite alternative (comment out ConvertKit above if using this)
# MAILERLITE_API_KEY=
# MAILERLITE_GROUP_ID=
